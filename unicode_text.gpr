with "sparklib";

project Unicode_Text is

   for Source_Dirs use ("src", "tests/proof");
   for Object_Dir use "obj";

   package Compiler is
      for Default_Switches ("Ada") use
        ("-gnat2022", "-gnata");
   end Compiler;

   package Prove is
      for Proof_Dir use "proof";
      for Proof_Switches ("Ada") use
        ("--mode=all", "--level=2", "--prover=cvc5", "--steps=10000");
   end Prove;

end Unicode_Text;
